# Auth — shared key for both MCP and gateway routes
OB2_BRAIN_KEY=change-me-to-a-random-string

# Server
OB2_PORT=7600
OB2_HOST=127.0.0.1

# Storage backend: two-tier (default) | sqlite | pgvector
# two-tier: SQLite write cache + pgvector query store (recommended for teams)
# sqlite:   SQLite only (single-user, dev, no pgvector needed)
# pgvector: pgvector only (direct writes, no cache layer)
OB2_STORAGE_BACKEND=two-tier
OB2_SQLITE_PATH=./ob2.db

# pgvector (required for two-tier and pgvector modes)
OB2_PG_URL=postgres://ob2:ob2secret@127.0.0.1:5433/ob2

# Sync worker (two-tier mode only)
OB2_SYNC_INTERVAL_SEC=5
OB2_SYNC_BATCH_SIZE=256

# Embedding model + batcher
# OB2_EMBEDDING_MODEL defaults to all-MiniLM-L6-v2 (384-dim).
# If you change it, also update OB2_EMBEDDING_DIM to match the model's output size.
OB2_EMBEDDING_MODEL=all-MiniLM-L6-v2
OB2_EMBEDDING_DIM=384
OB2_BATCH_FLUSH_MS=100
OB2_BATCH_MAX_SIZE=32

# Classifier-based auto-routing (opt-in)
# When true, queries without @prefix are classified by an LLM to decide
# whether a domain is relevant. Defaults to false (explicit @prefix only).
OB2_AUTO_ROUTE=false
# Model for classification (defaults to OB2_OLLAMA_MODEL if unset)
# OB2_CLASSIFIER_MODEL=gemma3:4b

# Multi-user auth — path to users.json
# If file doesn't exist, falls back to single-key mode via OB2_BRAIN_KEY.
OB2_USERS_FILE=../users.json

# Generation
OB2_OLLAMA_URL=http://localhost:11434
OB2_OLLAMA_MODEL=gemma3:4b

# Python sidecar
OB2_PYTHON=../retrieval/.venv/bin/python
OB2_SIDECAR_SCRIPT=../retrieval/sidecar.py
OB2_CONTEXT_ENGINE_PATH=/mnt/c/projects/context-engine
OB2_TOTAL_TOKEN_BUDGET=2048
OB2_RETRIEVAL_TOP_K=5
OB2_HYBRID_ALPHA=0.65

# Open WebUI chat surface (Docker only — requires --with-chat flag)
# Set ENABLED=true and provide a SERVICE_TOKEN to activate.
# Generate the token once with:
#   deno run --allow-env --allow-write server/scripts/openwebui-init.ts
OB2_OPENWEBUI_ENABLED=false
OB2_OPENWEBUI_SERVICE_TOKEN=
OB2_OPENWEBUI_PROXY_PORT=7601
# PUBLIC_URL: the externally-reachable URL for Open WebUI links in the dashboard.
# Defaults to http://localhost:7601 when unset.
OB2_OPENWEBUI_PUBLIC_URL=

# Upload provenance — include uploader name in multi-domain LLM context annotations.
# Default: true. Set to false to suppress from LLM responses without touching stored data.
# OB2_CONTEXT_SHOW_UPLOADER=false

# llama.cpp manager: generated automatically by scripts/docker-start.sh --with-llamacpp.
OB2_LLAMACPP_MANAGER_TOKEN=
# Optional HuggingFace token for gated repos:
OB2_HF_TOKEN=
